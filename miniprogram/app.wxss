/* 全局样式 */
page {
  background-color: #f2f9ea;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #2a3127;
}

/* 统一自定义页面头部：后续新增二级页面优先复用这组类 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(88rpx + env(safe-area-inset-top)) 32rpx 16rpx;
  background: #f0fdf4;
}

.icon-btn,
.header-spacer {
  width: 72rpx;
  height: 72rpx;
}

.icon-btn {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-btn image {
  width: 44rpx;
  height: 44rpx;
}

.header-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
}

/* 主题色 */
.primary {
  color: #176a21;
}

.bg-primary {
  background-color: #176a21;
}

.secondary {
  color: #3c6600;
}

.bg-secondary {
  background-color: #3c6600;
}

.tertiary {
  color: #755700;
}

.bg-tertiary {
  background-color: #fdc003;
}

/* 容器 */
.container {
  padding: 20rpx;
}

/* 卡片 */
.card {
  background-color: #ebf3e3;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(23, 106, 33, 0.06);
}

/* 按钮 */
.btn-primary {
  background-color: #176a21;
  color: #d1ffc8;
  border-radius: 9999rpx;
  padding: 20rpx 40rpx;
  font-weight: bold;
  text-align: center;
}

.btn-secondary {
  background-color: #9df197;
  color: #176a21;
  border-radius: 9999rpx;
  padding: 20rpx 40rpx;
  font-weight: bold;
  text-align: center;
}

/* 文字 */
.text-center {
  text-align: center;
}

.text-bold {
  font-weight: bold;
}

.text-sm {
  font-size: 24rpx;
}

.text-lg {
  font-size: 36rpx;
}

.text-xl {
  font-size: 48rpx;
}

/* Flex布局 */
.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* 间距 */
.mt-1 { margin-top: 8rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-4 { margin-top: 32rpx; }
.mb-1 { margin-bottom: 8rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-4 { margin-bottom: 32rpx; }
.p-2 { padding: 16rpx; }
.p-4 { padding: 32rpx; }
