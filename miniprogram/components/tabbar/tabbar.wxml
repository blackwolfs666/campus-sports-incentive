<view class="tabbar">
  <view 
    wx:for="{{list}}" 
    wx:key="index" 
    class="tabbar-item {{selected === index ? 'active' : ''}}"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <image class="tabbar-icon" src="{{selected === index ? item.activeIcon : item.icon}}" mode="aspectFit"></image>
    <text class="tabbar-text">{{item.text}}</text>
  </view>
</view>
