.page {
  min-height: 100vh;
  background: #f0fdf4;
  color: #111827;
}

.page-header {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(88rpx + env(safe-area-inset-top)) 32rpx 18rpx;
  background: #f0fdf4;
}

.icon-btn,
.header-spacer {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
}

.icon-btn image {
  width: 44rpx;
  height: 44rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 800;
}

.content {
  padding: 24rpx 32rpx 64rpx;
}

.notice,
.search-card,
.admin-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.notice {
  padding: 24rpx 28rpx;
  color: #6b7280;
  font-size: 24rpx;
  margin-bottom: 22rpx;
}

.search-card {
  padding: 24rpx;
  margin-bottom: 22rpx;
}

.search-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 150rpx;
  gap: 16rpx;
}

input {
  height: 72rpx;
  border-radius: 20rpx;
  background: #f9fafb;
  padding: 0 22rpx;
  box-sizing: border-box;
  font-size: 25rpx;
}

.admin-btn {
  width: 100%;
  min-width: 0;
  height: 72rpx;
  border-radius: 22rpx;
  background: #15803d;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  line-height: 1;
  white-space: nowrap;
}

.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

.candidate {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.candidate text {
  display: block;
}

.candidate text:first-child {
  font-size: 26rpx;
  font-weight: 800;
}

.candidate text:last-child {
  margin-top: 6rpx;
  color: #9ca3af;
  font-size: 22rpx;
}

.candidate .confirm {
  width: 160rpx;
  flex-shrink: 0;
}

.admin-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
}

.admin-card + .admin-card {
  margin-top: 18rpx;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
}

.admin-main {
  flex: 1;
  min-width: 0;
}

.name,
.meta,
.role {
  display: block;
}

.name {
  font-size: 27rpx;
  font-weight: 900;
}

.meta {
  margin-top: 4rpx;
  color: #9ca3af;
  font-size: 22rpx;
}

.role {
  margin-top: 8rpx;
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  color: #15803d;
  font-size: 21rpx;
  font-weight: 800;
}

.role.owner {
  background: #fff7ed;
  color: #c2410c;
}

.remove,
.disabled {
  width: 130rpx;
  flex-shrink: 0;
}

.remove {
  background: #ffffff;
  color: #ef4444;
  border: 2rpx solid #fecaca;
}
