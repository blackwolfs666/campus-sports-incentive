<view class="page">
  <view class="page-header">
    <view class="icon-btn" bindtap="goBack">
      <image src="/images/icons/arrow_back.svg" mode="aspectFit"></image>
    </view>
    <text class="header-title">{{activity.name}}：打卡动态</text>
    <view class="header-spacer"></view>
  </view>

  <view class="content">
    <view class="filters">
      <view class="filter {{scope === 'mine' ? 'active' : ''}}" data-scope="mine" bindtap="switchScope">我的动态</view>
      <view class="filter {{scope === 'all' ? 'active' : ''}}" data-scope="all" bindtap="switchScope">全部动态</view>
    </view>

    <view class="list">
      <view wx:if="{{!isLoading && posts.length === 0}}" class="empty">
        <text>暂无动态，去打卡发布动态吧</text>
        <button wx:if="{{!isEnded}}" bindtap="goCheckin">返回同步打卡</button>
        <text wx:else class="ended-tip">活动已结束，仅可查看历史动态</text>
      </view>

      <view wx:for="{{posts}}" wx:key="id" class="post-card">
        <view class="post-head">
          <image class="avatar" src="{{item.user_avatar || '/images/icons/person.svg'}}" mode="aspectFill"></image>
          <view class="user-main">
            <view class="name-row">
              <text class="name">{{item.user_name}}</text>
              <text wx:if="{{item.is_mine}}" class="mine">我</text>
            </view>
            <text class="meta">{{item.department_name || '未设置部门'}} · {{item.createdText}}</text>
          </view>
        </view>

        <text wx:if="{{item.content}}" class="content">{{item.content}}</text>

        <view wx:if="{{item.images.length}}" class="image-grid count-{{item.images.length}}">
          <image
            wx:for="{{item.images}}"
            wx:for-item="img"
            wx:key="*this"
            class="feed-image"
            src="{{img}}"
            mode="aspectFill"
            data-src="{{img}}"
            data-post-id="{{item.id}}"
            bindtap="previewImage"
          ></image>
        </view>

        <view class="stats">
          <view>
            <text>今日打卡步数</text>
            <text>{{item.steps}} 步</text>
          </view>
          <view>
            <text>连续打卡天数</text>
            <text>{{item.streak_days}} 天</text>
          </view>
        </view>

        <view class="post-actions">
          <view class="cheer {{item.has_cheered ? 'cheered' : ''}}" data-id="{{item.id}}" bindtap="cheerPost">
            {{item.has_cheered ? '已加油' : '为TA加油'}} {{item.cheer_count}}
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
