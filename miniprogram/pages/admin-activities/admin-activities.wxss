.page {
  min-height: 100vh;
  background: #f0fdf4;
  color: #111827;
}

.page-header {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(88rpx + env(safe-area-inset-top)) 32rpx 18rpx;
  background: #f0fdf4;
}

.icon-btn,
.header-spacer {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
}

.icon-btn image {
  width: 44rpx;
  height: 44rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 800;
}

.content {
  padding: 24rpx 32rpx 64rpx;
}

.admin-btn {
  width: 100%;
  min-width: 0;
  height: 76rpx;
  border-radius: 24rpx;
  background: #15803d;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  line-height: 1;
  white-space: nowrap;
}

.admin-btn.outline {
  background: #ffffff;
  color: #15803d;
  border: 2rpx solid #86efac;
}

.admin-btn.disabled {
  background: #e5e7eb;
  color: #9ca3af;
  border-color: #e5e7eb;
}

.admin-btn.muted {
  background: #f3f4f6;
  color: #4b5563;
}

.create-btn {
  width: 100%;
  margin-bottom: 18rpx;
}

.filter-tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  padding: 10rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
}

.filter-tab {
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 800;
  background: #f3f4f6;
  box-sizing: border-box;
  white-space: nowrap;
}

.filter-tab.active {
  background: #15803d;
  color: #ffffff;
}

.activity-card,
.empty {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.activity-card {
  padding: 28rpx;
}

.activity-card + .activity-card {
  margin-top: 22rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status,
.role {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.status {
  background: #dcfce7;
  color: #15803d;
}

.status.ended {
  background: #f3f4f6;
  color: #6b7280;
}

.role {
  background: #fff7ed;
  color: #c2410c;
}

.title,
.desc {
  display: block;
}

.title {
  margin-top: 20rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.meta {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.actions {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.empty {
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  color: #6b7280;
}

.empty image {
  width: 72rpx;
  height: 72rpx;
}

.empty-btn {
  width: 220rpx;
}
