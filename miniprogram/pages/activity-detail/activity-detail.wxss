.page {
  height: 100vh;
  background: #f0fdf4;
  color: #111827;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.scroll-area {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 24rpx;
}

.hero {
  position: relative;
  height: 416rpx;
}

.hero.green {
  background: linear-gradient(135deg, #14532d, #22c55e);
}

.hero.blue {
  background: linear-gradient(135deg, #1e3a8a, #38bdf8);
}

.hero.orange {
  background: linear-gradient(135deg, #9a3412, #fb923c);
}

.hero.gray {
  background: linear-gradient(135deg, #374151, #9ca3af);
}

.hero-shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.04), rgba(0, 0, 0, 0.5));
}

.hero-fade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -1rpx;
  height: 72rpx;
  background: linear-gradient(180deg, rgba(240, 253, 244, 0), rgba(240, 253, 244, 0.16) 62%, rgba(240, 253, 244, 0.38));
  pointer-events: none;
}

.hero-actions {
  position: absolute;
  left: 0;
  right: 0;
  top: calc(88rpx + env(safe-area-inset-top));
  padding: 0 32rpx;
  display: flex;
  justify-content: space-between;
}

.circle-btn,
.hero-action-spacer {
  width: 72rpx;
  height: 72rpx;
}

.circle-btn {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.82);
  display: flex;
  align-items: center;
  justify-content: center;
}

.circle-btn image {
  width: 38rpx;
  height: 38rpx;
}

.content {
  position: relative;
  margin-top: -32rpx;
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.title-card,
.card {
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.title-card {
  padding: 32rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tags text {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  color: #15803d;
  font-size: 23rpx;
  font-weight: 600;
}

.title {
  display: block;
  color: #111827;
  font-size: 40rpx;
  line-height: 1.25;
  font-weight: 800;
}

.intro {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 27rpx;
  line-height: 1.55;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 28rpx;
}

.info-line {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.info-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #dcfce7;
  color: #166534;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.info-icon image {
  width: 28rpx;
  height: 28rpx;
  opacity: 1;
  filter: none;
}

.info-label,
.info-value {
  display: block;
}

.info-label {
  color: #9ca3af;
  font-size: 22rpx;
  font-weight: 500;
}

.info-value {
  margin-top: 4rpx;
  color: #374151;
  font-size: 26rpx;
  font-weight: 700;
}

.card {
  padding: 32rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.section-title image {
  width: 32rpx;
  height: 32rpx;
}

.detail-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.detail-stats view {
  border-radius: 24rpx;
  padding: 22rpx 12rpx;
  text-align: center;
}

.detail-stats view:nth-child(1) {
  background: #f0fdf4;
}

.detail-stats view:nth-child(2) {
  background: #fffbeb;
}

.detail-stats view:nth-child(3) {
  background: #eff6ff;
}

.tiny,
.stat-value {
  display: block;
}

.tiny {
  margin-bottom: 8rpx;
  font-size: 22rpx;
}

.green {
  color: #15803d;
}

.amber {
  color: #d97706;
}

.blue {
  color: #2563eb;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 800;
}

.rank-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(90deg, #15803d, #16a34a);
  color: #ffffff;
}

.rank-banner text {
  display: block;
}

.rank-banner text:first-child {
  color: #bbf7d0;
  font-size: 23rpx;
}

.rank-banner text:last-child {
  margin-top: 4rpx;
  font-size: 44rpx;
  font-weight: 800;
}

.rank-banner image {
  width: 56rpx;
  height: 56rpx;
  opacity: 0.35;
}

.rank-tip {
  display: block;
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 27rpx;
  text-align: center;
}

.ended-card {
  text-align: center;
}

.ended-pill {
  display: inline-block;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 600;
}

.ended-label,
.ended-rank {
  display: block;
}

.ended-label {
  margin-top: 28rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.ended-rank {
  margin-top: 8rpx;
  color: #166534;
  font-size: 64rpx;
  font-weight: 900;
}

.won-prize {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  color: #b45309;
  font-size: 26rpx;
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.won-prize image {
  width: 32rpx;
  height: 32rpx;
}

.rule-line {
  display: flex;
  gap: 14rpx;
  margin-top: 16rpx;
  color: #4b5563;
  font-size: 27rpx;
  line-height: 1.55;
}

.rule-num {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  border-radius: 50%;
  background: #dcfce7;
  color: #15803d;
  font-size: 22rpx;
  text-align: center;
  font-weight: 700;
  flex-shrink: 0;
}

.prize-scroll {
  white-space: nowrap;
}

.prize-row {
  display: flex;
  gap: 20rpx;
  padding-bottom: 4rpx;
}

.prize-card {
  width: 224rpx;
  padding: 24rpx 16rpx;
  border-radius: 24rpx;
  background: #f0fdf4;
  border: 1rpx solid #dcfce7;
  text-align: center;
  box-sizing: border-box;
  flex-shrink: 0;
}

.prize-card.gold {
  background: #fffbeb;
  border-color: #fde68a;
}

.prize-rank {
  display: inline-block;
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  background: #bbf7d0;
  color: #166534;
  font-size: 22rpx;
  font-weight: 700;
}

.gold .prize-rank {
  background: #fde68a;
  color: #92400e;
}

.prize-image {
  display: block;
  width: 112rpx;
  height: 82rpx;
  margin: 16rpx auto 10rpx;
}

.prize-name {
  display: block;
  color: #374151;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 600;
}

.bottom-actions {
  flex-shrink: 0;
  width: 100%;
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f3f4f6;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
  overflow: hidden;
}

.primary,
.outline {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 96rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  line-height: 1;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}

.primary {
  background: #15803d;
  color: #ffffff;
}

.long-primary {
  display: flex;
  width: 100%;
  max-width: 100%;
  margin: 0 auto;
  min-height: 88rpx;
  height: 88rpx;
  border-radius: 32rpx;
  padding: 0 8rpx;
  font-size: 24rpx;
  letter-spacing: 0;
  box-sizing: border-box;
}

.long-primary-text {
  display: block;
  width: 100%;
  white-space: nowrap;
  overflow: visible;
  text-align: center;
  line-height: 1;
  font-size: 24rpx;
  font-weight: 800;
}

.outline {
  background: #ffffff;
  color: #15803d;
  border: 2rpx solid #86efac;
}

.primary::after,
.outline::after {
  border: 0;
}

.action-stack {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: stretch;
  box-sizing: border-box;
}

.action-stack > .primary {
  width: 100%;
  align-self: stretch;
}

.quick-actions {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  box-sizing: border-box;
}

.quick-actions .outline {
  width: 100%;
  min-width: 0;
  height: 78rpx;
  padding: 0 4rpx;
  font-size: 24rpx;
  border-radius: 26rpx;
  white-space: nowrap;
  overflow: hidden;
}

.ended-actions {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.ended-actions .primary {
  width: 100%;
  min-width: 0;
  height: 78rpx;
  padding: 0 4rpx;
  font-size: 24rpx;
  border-radius: 26rpx;
  white-space: nowrap;
  overflow: hidden;
}

.closed {
  padding: 28rpx;
  border-radius: 32rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 27rpx;
  text-align: center;
}
