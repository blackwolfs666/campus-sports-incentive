.page {
  min-height: 100vh;
  background: #f0fdf4;
  color: #111827;
}

.page-header {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(88rpx + env(safe-area-inset-top)) 32rpx 18rpx;
  background: #f0fdf4;
}

.icon-btn,
.header-spacer {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
}

.icon-btn image {
  width: 44rpx;
  height: 44rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
}

.content {
  padding: 24rpx 32rpx 64rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero,
.section,
.summary-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.hero {
  padding: 30rpx;
}

.hero-title,
.hero-subtitle {
  display: block;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 900;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.hero-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 26rpx;
  width: 100%;
  box-sizing: border-box;
}

.action-btn {
  width: 100%;
  min-width: 0;
  height: 76rpx;
  border-radius: 24rpx;
  background: #15803d;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  line-height: 1;
  white-space: nowrap;
}

.action-btn.outline {
  background: #ffffff;
  color: #15803d;
  border: 2rpx solid #86efac;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.summary-card {
  padding: 28rpx;
}

.summary-card text {
  display: block;
}

.summary-card text:first-child {
  color: #15803d;
  font-size: 42rpx;
  font-weight: 900;
}

.summary-card text:last-child {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.section {
  padding: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.section-title image {
  width: 34rpx;
  height: 34rpx;
}

.section-title text {
  font-size: 29rpx;
  font-weight: 900;
}

.status-row {
  display: grid;
  grid-template-columns: 180rpx 1fr 42rpx;
  align-items: center;
  gap: 16rpx;
  color: #4b5563;
  font-size: 24rpx;
}

.status-row + .status-row {
  margin-top: 18rpx;
}

.bar {
  height: 14rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #15803d;
}

.trend-wrap {
  position: relative;
  padding-top: 34rpx;
}

.average-line {
  position: absolute;
  left: 0;
  right: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 10rpx;
  pointer-events: none;
}

.average-line view {
  flex: 1;
  height: 2rpx;
  background: #9ca3af;
  opacity: 0.8;
}

.average-line text {
  flex: none;
  color: #6b7280;
  font-size: 20rpx;
  font-weight: 800;
  background: #f3f4f6;
  border-radius: 999rpx;
  padding: 4rpx 10rpx;
}

.trend {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  align-items: end;
  gap: 12rpx;
  min-height: 190rpx;
}

.trend-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.trend-bar {
  width: 34rpx;
  border-radius: 999rpx;
  background: #22c55e;
}

.trend-item text {
  color: #9ca3af;
  font-size: 20rpx;
}

.trend-item .trend-value {
  color: #15803d;
  font-size: 20rpx;
  font-weight: 800;
  min-height: 24rpx;
}

.trend-item .trend-date {
  color: #9ca3af;
  font-size: 20rpx;
}

.empty {
  color: #9ca3af;
  text-align: center;
  padding: 40rpx 0;
}

.top-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.top-item + .top-item {
  border-top: 1rpx solid #f3f4f6;
}

.top-title,
.top-meta {
  display: block;
}

.top-title {
  font-size: 26rpx;
  font-weight: 800;
}

.top-meta {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.top-item image {
  width: 30rpx;
  height: 30rpx;
  opacity: 0.45;
}
