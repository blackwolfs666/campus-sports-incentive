.page {
  min-height: 100vh;
  background: #f0fdf4;
  color: #111827;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(88rpx + env(safe-area-inset-top)) 32rpx 16rpx;
  background: #f0fdf4;
}

.icon-btn,
.header-spacer {
  width: 72rpx;
  height: 72rpx;
}

.icon-btn {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-btn image {
  width: 44rpx;
  height: 44rpx;
}

.header-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
}

.content {
  padding: 0 32rpx 180rpx;
}

.segmented {
  display: flex;
  padding: 8rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.segment {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 18rpx;
  color: #6b7280;
  font-size: 26rpx;
  text-align: center;
}

.segment.active {
  background: #15803d;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(21, 128, 61, 0.16);
}

.count-text {
  display: block;
  margin: 22rpx 0;
  color: #6b7280;
  font-size: 26rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 24rpx;
}

.prize-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.prize-card.muted {
  opacity: 0.75;
}

.icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #fef3c7;
}

.icon-wrap.claimed {
  background: #dcfce7;
}

.icon-wrap.redeemed {
  background: #dcfce7;
}

.icon-wrap.expired {
  background: #f3f4f6;
}

.icon-wrap image {
  width: 42rpx;
  height: 42rpx;
}

.info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
  min-width: 0;
}

.name {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-pill {
  flex-shrink: 0;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.status-pill.pending {
  background: #ffedd5;
  color: #ea580c;
}

.status-pill.claimed {
  background: #dcfce7;
  color: #15803d;
}

.status-pill.redeemed {
  background: #dcfce7;
  color: #15803d;
}

.status-pill.expired {
  background: #f3f4f6;
  color: #6b7280;
}

.source,
.time {
  display: block;
  color: #9ca3af;
  font-size: 23rpx;
  line-height: 1.45;
}

.action,
.outline-action {
  flex-shrink: 0;
  width: 148rpx;
  min-width: 0;
  height: 64rpx;
  padding: 0;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  line-height: 1;
  box-sizing: border-box;
}

.action {
  background: #15803d;
  color: #ffffff;
}

.outline-action {
  background: #ffffff;
  color: #6b7280;
  border: 1rpx solid #e5e7eb;
}

.action::after,
.outline-action::after,
.empty button::after {
  border: 0;
}

.empty {
  margin-top: 24rpx;
  padding: 64rpx 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
  text-align: center;
}

.empty-icon {
  width: 112rpx;
  height: 112rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  background: #f0fdf4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon image {
  width: 56rpx;
  height: 56rpx;
  opacity: 0.55;
}

.empty-title,
.empty-desc {
  display: block;
}

.empty-title {
  color: #6b7280;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-desc {
  margin: 8rpx 0 24rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.empty button {
  width: 220rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: #15803d;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0 auto;
  line-height: 1;
  box-sizing: border-box;
}
