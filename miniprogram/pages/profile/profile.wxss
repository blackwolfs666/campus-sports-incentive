.page {
  min-height: 100vh;
  background: #f0fdf4;
  color: #111827;
}

.page-header {
  position: sticky;
  top: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(88rpx + env(safe-area-inset-top)) 32rpx 16rpx;
  background: #f0fdf4;
}

.header-side {
  position: relative;
  width: 80rpx;
  display: flex;
  align-items: center;
}

.header-side.right {
  justify-content: flex-end;
}

.header-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 4rpx solid #bbf7d0;
}

.header-title {
  color: #15803d;
  font-size: 34rpx;
  font-weight: 700;
}

.content {
  padding: 24rpx 32rpx calc(260rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.user-card,
.stat-card,
.menu-card,
.logout-card {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.user-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 32rpx;
}

.avatar-box {
  position: relative;
  flex-shrink: 0;
}

.big-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.15);
}

.avatar-badge {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #f59e0b;
  border: 4rpx solid #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-badge image {
  width: 22rpx;
  height: 22rpx;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name,
.user-meta,
.college {
  display: block;
}

.user-name {
  color: #111827;
  font-size: 36rpx;
  font-weight: 800;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 6rpx;
  min-width: 0;
  color: #6b7280;
  font-size: 26rpx;
}

.user-id {
  flex-shrink: 0;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 400;
}

.meta-separator {
  flex-shrink: 0;
  color: #6b7280;
  font-size: 26rpx;
}

.college {
  flex: 1;
  min-width: 0;
  color: #6b7280;
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badges {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.badges text {
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  color: #15803d;
  font-size: 21rpx;
  font-weight: 600;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.stat-card {
  padding: 24rpx 16rpx;
  text-align: center;
}

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 14rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #dcfce7;
}

.stat-icon.green {
  background: #dcfce7;
}

.stat-icon.blue {
  background: #dcfce7;
}

.stat-icon.amber {
  background: #dcfce7;
}

.stat-icon image {
  width: 32rpx;
  height: 32rpx;
}

.stat-num,
.stat-label {
  display: block;
}

.stat-num {
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 6rpx;
  color: #9ca3af;
  font-size: 22rpx;
}

.menu-item,
.logout-card {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #dcfce7;
}

.menu-icon.green {
  background: #dcfce7;
}

.menu-icon image {
  width: 36rpx;
  height: 36rpx;
}

.chevron {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.45;
}

.menu-card {
  overflow: hidden;
}

.menu-item {
  gap: 22rpx;
  padding: 30rpx 32rpx;
}

.menu-item + .menu-item {
  border-top: 1rpx solid #f3f4f6;
}

.menu-icon.amber {
  background: #dcfce7;
}

.menu-icon.blue {
  background: #dcfce7;
}

.menu-icon.gray {
  background: #dcfce7;
}

.menu-icon.red {
  background: #dcfce7;
}

.menu-copy {
  flex: 1;
}

.menu-copy text {
  display: block;
}

.menu-copy text:first-child {
  color: #374151;
  font-size: 27rpx;
  font-weight: 700;
}

.menu-copy text:last-child {
  margin-top: 4rpx;
  color: #9ca3af;
  font-size: 22rpx;
}

.badge {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  border-radius: 50%;
  background: #f59e0b;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
}

.logout-card {
  gap: 22rpx;
  padding: 30rpx 32rpx;
}

.logout-card text {
  flex: 1;
  color: #ef4444;
  font-size: 27rpx;
  font-weight: 700;
}
