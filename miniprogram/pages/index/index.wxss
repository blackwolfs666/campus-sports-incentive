.page {
  min-height: 100vh;
  background: #f0fdf4;
  color: #111827;
}

.page-header {
  position: sticky;
  top: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(88rpx + env(safe-area-inset-top)) 32rpx 16rpx;
  background: #f0fdf4;
}

.header-side {
  position: relative;
  width: 80rpx;
  display: flex;
  align-items: center;
}

.header-side.right {
  justify-content: flex-end;
}

.header-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 4rpx solid #bbf7d0;
}

.header-title {
  color: #15803d;
  font-size: 34rpx;
  font-weight: 700;
}

.header-icon {
  width: 40rpx;
  height: 40rpx;
}

.notice-dot {
  position: absolute;
  right: 2rpx;
  top: 6rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ef4444;
}

.content {
  padding: 24rpx 32rpx calc(260rpx + env(safe-area-inset-bottom));
}

.steps-card,
.activity-card,
.empty-activity,
.calendar-card {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.steps-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.steps-card:active {
  transform: scale(0.995);
}

.card-top,
.section-head,
.activity-strip,
.rank-row,
.action-row,
.stat-label-line,
.strip-left {
  display: flex;
  align-items: center;
}

.card-top,
.section-head,
.activity-strip,
.rank-row {
  justify-content: space-between;
}

.muted {
  color: #6b7280;
  font-size: 28rpx;
}

.streak-pill {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #fffbeb;
  color: #d97706;
  font-size: 22rpx;
  font-weight: 700;
}

.streak-pill.light {
  background: #fef3c7;
}

.steps-row {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  margin: 22rpx 0 24rpx;
}

.steps-num {
  color: #166534;
  font-size: 84rpx;
  line-height: 1;
  font-weight: 800;
}

.steps-goal {
  color: #9ca3af;
  font-size: 36rpx;
}

.progress-track {
  position: relative;
  height: 24rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  overflow: visible;
}

.progress-fill {
  height: 24rpx;
  max-width: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #22c55e, #4ade80);
}

.progress-thumb {
  position: absolute;
  top: -8rpx;
  width: 40rpx;
  height: 40rpx;
  margin-left: -20rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 4rpx solid #22c55e;
  box-shadow: 0 4rpx 12rpx rgba(22, 163, 74, 0.25);
}

.progress-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.progress-meta .success {
  color: #16a34a;
  font-weight: 700;
}

.goal-reset-tip {
  display: block;
  margin-top: 18rpx;
  color: #9ca3af;
  font-size: 22rpx;
  text-align: right;
}

.sync-button {
  width: 100%;
  display: flex;
  min-height: 118rpx;
  margin: 0 0 24rpx;
  padding: 24rpx 32rpx;
  border-radius: 32rpx;
  background: #15803d;
  color: #ffffff;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  box-sizing: border-box;
}

.sync-button::after,
.primary-mini::after,
.outline-mini::after,
.empty-activity button::after {
  border: 0;
}

.sync-button image {
  width: 40rpx;
  height: 40rpx;
  filter: brightness(0) invert(1);
}

.sync-copy {
  display: flex;
  flex-direction: column;
  text-align: left;
}

.sync-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.25;
}

.sync-subtitle {
  margin-top: 4rpx;
  color: #bbf7d0;
  font-size: 23rpx;
}

.activity-card {
  overflow: hidden;
  margin-bottom: 24rpx;
  border: 1rpx solid #dcfce7;
}

.activity-strip {
  padding: 24rpx 32rpx;
  background: linear-gradient(90deg, #15803d, #16a34a);
  color: #bbf7d0;
  font-size: 24rpx;
}

.strip-left {
  gap: 12rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.strip-left image {
  width: 32rpx;
  height: 32rpx;
}

.activity-switch {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #dcfce7;
  font-size: 24rpx;
  font-weight: 700;
}

.switch-btn {
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 34rpx;
  text-align: center;
  box-sizing: border-box;
}

.activity-body {
  padding: 32rpx;
}

.activity-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.activity-title {
  flex: 1;
  color: #111827;
  font-size: 36rpx;
  line-height: 1.25;
  font-weight: 800;
}

.activity-end {
  flex-shrink: 0;
  padding-top: 4rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.25;
}

.activity-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.activity-stat {
  padding: 24rpx;
  border-radius: 24rpx;
}

.activity-stat.green {
  background: #f0fdf4;
}

.activity-stat.amber {
  background: #fffbeb;
}

.stat-label-line {
  gap: 8rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
}

.stat-label-line image {
  width: 26rpx;
  height: 26rpx;
}

.green .stat-label-line {
  color: #16a34a;
}

.amber .stat-label-line {
  color: #d97706;
}

.stat-main {
  color: #166534;
  font-size: 36rpx;
  font-weight: 800;
}

.amber .stat-main {
  color: #b45309;
}

.stat-unit {
  margin-left: 6rpx;
  font-size: 22rpx;
  color: #16a34a;
}

.amber .stat-unit {
  color: #d97706;
}

.rank-row {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: #f0fdf4;
  margin-bottom: 24rpx;
}

.rank-label {
  margin-right: 12rpx;
  color: #15803d;
  font-size: 27rpx;
}

.rank-value {
  color: #166534;
  font-size: 27rpx;
  font-weight: 800;
}

.rank-gap {
  color: #f97316;
  font-size: 23rpx;
}

.action-row {
  gap: 16rpx;
}

.primary-mini,
.outline-mini,
.empty-activity button {
  flex: 1;
  height: 84rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  line-height: 1;
  box-sizing: border-box;
}

.primary-mini {
  background: #15803d;
  color: #ffffff;
}

.outline-mini {
  background: #ffffff;
  color: #15803d;
  border: 2rpx solid #86efac;
}

.empty-activity {
  padding: 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
  border: 2rpx dashed #bbf7d0;
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  background: #f0fdf4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon image {
  width: 48rpx;
  height: 48rpx;
}

.empty-title,
.empty-text {
  display: block;
}

.empty-title {
  color: #4b5563;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-text {
  margin: 8rpx 0 24rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.empty-activity button {
  width: 220rpx;
  margin: 0 auto;
  background: #15803d;
  color: #ffffff;
}

.calendar-card {
  padding: 32rpx;
}

.section-head {
  margin-bottom: 24rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-row text {
  padding: 8rpx 0;
  color: #9ca3af;
  font-size: 23rpx;
  text-align: center;
}

.calendar-cell {
  min-height: 82rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.day-dot {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 50%;
  color: #9ca3af;
  font-size: 26rpx;
  text-align: center;
}

.day-dot.future {
  color: #d1d5db;
}

.day-dot.has {
  color: #15803d;
  background: #dcfce7;
}

.day-dot.hit,
.day-dot.today {
  color: #ffffff;
  background: #16a34a;
  font-weight: 800;
}

.steps-label {
  margin-top: 4rpx;
  color: transparent;
  font-size: 18rpx;
  line-height: 1;
}

.steps-label.hit-text {
  color: #16a34a;
  font-weight: 700;
}

.steps-label.has-text {
  color: #f59e0b;
  font-weight: 700;
}

.steps-label.missed-text {
  color: #d1d5db;
}
