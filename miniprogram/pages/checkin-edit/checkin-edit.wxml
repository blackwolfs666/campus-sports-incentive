<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <image src="/images/icons/arrow_back.svg" mode="aspectFit"></image>
    </view>
    <view class="header-title">
      <text>发布打卡动态</text>
      <text>{{activity.name}}</text>
    </view>
    <view class="header-spacer"></view>
  </view>

  <view class="summary">
    <view>
      <text>今日打卡步数</text>
      <text>{{steps}} 步</text>
    </view>
    <view>
      <text>连续打卡天数</text>
      <text>{{streakDays}} 天</text>
    </view>
  </view>

  <view class="card">
    <view class="label">想说的话</view>
    <textarea
      class="textarea"
      maxlength="500"
      placeholder="记录今天的运动感受..."
      value="{{content}}"
      bindinput="onContentInput"
    ></textarea>
    <view class="count">{{content.length}} / 500</view>
  </view>

  <view class="card">
    <view class="label">展示风采</view>
    <view class="image-row">
      <view wx:for="{{images}}" wx:key="*this" class="image-wrap">
        <image class="preview" src="{{item}}" mode="aspectFill" data-src="{{item}}" bindtap="previewImage"></image>
        <view class="remove" data-index="{{index}}" bindtap="removeImage">×</view>
      </view>
      <view wx:if="{{images.length < 3}}" class="add-image" bindtap="chooseImages">
        <text>+</text>
        <text>添加图片</text>
      </view>
    </view>
  </view>

  <view class="bottom-actions">
    <button class="submit" bindtap="submitPost">{{isSubmitting ? '发布中...' : '发布'}}</button>
  </view>
</view>
