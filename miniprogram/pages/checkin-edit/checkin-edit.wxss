.page {
  min-height: 100vh;
  background: #f0fdf4;
  color: #111827;
  padding: calc(32rpx + env(safe-area-inset-top)) 32rpx calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  gap: 16rpx;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn image {
  width: 36rpx;
  height: 36rpx;
}

.header-title {
  min-width: 0;
  text-align: center;
}

.header-title text {
  display: block;
}

.header-title text:first-child {
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
}

.header-title text:last-child {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary {
  margin-top: 32rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.summary view {
  border-radius: 28rpx;
  background: #ffffff;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

.summary text {
  display: block;
}

.summary text:first-child {
  color: #15803d;
  font-size: 24rpx;
  font-weight: 700;
}

.summary text:last-child {
  margin-top: 10rpx;
  color: #166534;
  font-size: 38rpx;
  font-weight: 900;
}

.card {
  margin-top: 24rpx;
  border-radius: 32rpx;
  background: #ffffff;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

.label {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.textarea {
  width: 100%;
  height: 260rpx;
  border-radius: 24rpx;
  background: #f9fafb;
  color: #374151;
  font-size: 28rpx;
  line-height: 1.5;
  padding: 22rpx;
  box-sizing: border-box;
}

.count {
  margin-top: 12rpx;
  color: #9ca3af;
  font-size: 22rpx;
  text-align: right;
}

.image-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.image-wrap,
.add-image {
  position: relative;
  height: 190rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.preview {
  width: 100%;
  height: 100%;
  background: #f3f4f6;
}

.remove {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.72);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 36rpx;
  text-align: center;
}

.add-image {
  border: 2rpx dashed #86efac;
  background: #f0fdf4;
  color: #15803d;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-image text:first-child {
  font-size: 48rpx;
  line-height: 1;
  font-weight: 300;
}

.add-image text:last-child {
  font-size: 23rpx;
  font-weight: 700;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.submit {
  width: 100%;
  height: 88rpx;
  border-radius: 30rpx;
  background: #15803d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  padding: 0;
}

.submit::after {
  border: 0;
}
