.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  height: calc(132rpx + env(safe-area-inset-bottom));
  padding: 16rpx 48rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #f0fdf4;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.tabbar::before {
  content: '';
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  top: 16rpx;
  bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.12);
}

.tabbar-item {
  position: relative;
  z-index: 1;
  flex: 1;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.tabbar-icon-wrapper {
  width: 88rpx;
  height: 58rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tabbar-item.active .tabbar-icon-wrapper {
  background: #15803d;
}

.tabbar-icon {
  width: 38rpx;
  height: 38rpx;
  opacity: 0.45;
}

.tabbar-item.active .tabbar-icon {
  opacity: 1;
  filter: brightness(0) invert(1);
}

.tabbar-text {
  color: #9ca3af;
  font-size: 22rpx;
  line-height: 1;
  margin-top: 2rpx;
}

.tabbar-item.active .tabbar-text {
  color: #15803d;
  font-weight: 700;
}
